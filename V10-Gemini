import os
import re
import warnings
import numpy as np
import pandas as pd
from sklearn.preprocessing import StandardScaler
from sklearn.model_selection import train_test_split
from sklearn.ensemble import RandomForestRegressor, GradientBoostingRegressor


warnings.filterwarnings("ignore")

# ---------------------------------------------------------
# 2. 读取 Hitachi EEM 文件 (只增强了兼容性，逻辑不变)
# ---------------------------------------------------------
def read_hitachi_eem(filepath):
    try:
        with open(filepath, 'r', encoding='utf-8', errors='ignore') as f:
            lines = f.readlines()
        start_idx = None
        for i, line in enumerate(lines):
            # 兼容 Peaks 和 Data 两种开头
            if "Peaks" in line or "Data" in line:
                start_idx = i + 2
                break
        if start_idx is None: return pd.DataFrame()

        data = []
        for line in lines[start_idx:]:
            parts = re.split(r'\s+', line.strip())
            if len(parts) < 3: continue
            try:
                ex_em = parts[1].replace(',', '').strip()
                intensity = float(parts[2])
                if '/' in ex_em:
                    ex, em = ex_em.split('/')
                elif '\\' in ex_em:
                    ex, em = ex_em.split('\\')
                else:
                    ex, em = parts[0], parts[1]
                data.append([float(ex), float(em), intensity])
            except:
                continue

        if not data: return pd.DataFrame()
        df = pd.DataFrame(data, columns=['Ex', 'Em', 'Intensity'])
        # 你的原始逻辑：透视表
        eem = df.pivot_table(index='Ex', columns='Em', values='Intensity', aggfunc='mean')
        return eem.sort_index(axis=0).sort_index(axis=1)
    except:
        return pd.DataFrame()


# ---------------------------------------------------------
# 3. 计算特征 (完全回归你的 A 模型：直接平均，不去散射)
# ---------------------------------------------------------
def calc_features(eem):
    if eem.empty:
        # 如果读不到，返回0而不是NaN，防止后续报错
        return {f"R{i}": 0 for i in range(1, 6)}, 0

    # 你的原始函数 (没有任何修改)
    def mean_region(eem, ex_range, em_range):
        sub = eem.loc[
            (eem.index >= ex_range[0]) & (eem.index <= ex_range[1]),
            (eem.columns >= em_range[0]) & (eem.columns <= em_range[1])
        ]
        if sub.empty: return 0
        return sub.mean().mean()  # 直接平均

    regions = {
        "R1": mean_region(eem, (200, 250), (250, 330)),
        "R2": mean_region(eem, (200, 250), (330, 380)),
        "R3": mean_region(eem, (200, 250), (380, 550)),
        "R4": mean_region(eem, (250, 380), (250, 380)),
        "R5": mean_region(eem, (250, 450), (380, 550)),
    }

    # HIX 计算 (只加了一个防除以零的判断)
    try:
        ex_target = 254
        # 找最近的波长 (防止文件里没有精确的254)
        idx = np.abs(eem.index.values - ex_target).argmin()
        row = eem.iloc[idx]

        low_vals = row[(row.index >= 300) & (row.index <= 345)]
        high_vals = row[(row.index >= 435) & (row.index <= 480)]

        low_mean = low_vals.mean()
        high_mean = high_vals.mean()

        # 【唯一修改】：防止分母为0导致 NaN
        if (low_mean + high_mean) == 0:
            HIX_norm = 0
        else:
            HIX_norm = high_mean / (low_mean + high_mean)

        # 防止算出无穷大
        if np.isnan(HIX_norm) or np.isinf(HIX_norm): HIX_norm = 0

    except:
        HIX_norm = 0

    return regions, HIX_norm


# ---------------------------------------------------------
# 4. 解析文件名
# ---------------------------------------------------------
def parse_sample_conditions(sample_label):
    PS, KOH, Microwave = 0, 0, 0
    try:
        pattern = r'(\d+\.?\d*)\+(\d+\.?\d*)(?:\+(\d+\.?\d*))?'
        match = re.search(pattern, sample_label)
        if match:
            PS = float(match.group(1))
            KOH = float(match.group(2))
            Microwave = float(match.group(3)) if match.group(3) else 0
    except:
        pass
    return PS, KOH, Microwave


# ---------------------------------------------------------
# 5. 主程序
# ---------------------------------------------------------
if __name__ == "__main__":
    folder = r"E:\桌面\0"  # 你的路径

    print(">>> 开始读取数据...")

    # 忽略大小写，读取所有 txt
    files = [f for f in os.listdir(folder) if f.lower().endswith(".txt")]
    print(f"发现文件数量: {len(files)}")

    results = []
    for file in files:
        path = os.path.join(folder, file)
        label = os.path.splitext(file)[0]

        try:
            eem = read_hitachi_eem(path)
            regions, HIX_norm = calc_features(eem)
            PS, KOH, Microwave = parse_sample_conditions(label)

            # 只有全0时才微扰，平时保持原样
            if PS == 0 and KOH == 0 and Microwave == 0:
                PS += 0.001

            row = [label, PS, KOH, Microwave, HIX_norm] + [regions[f"R{i}"] for i in range(1, 6)]
            results.append(row)
        except:
            pass

    df = pd.DataFrame(results,
                      columns=["Sample", "PS", "KOH", "Microwave", "HIX_normalized", "R1", "R2", "R3", "R4", "R5"])

    # -------------------
    # 数据清洗 (不再随意删除，而是用均值填充)
    # -------------------
    print(f"原始读取行数: {len(df)}")

    # 1. 如果 HIX 是 0 (计算失败)，用平均值代替，不要删掉它！
    mean_hix = df.loc[df['HIX_normalized'] > 0, 'HIX_normalized'].mean()
    df['HIX_normalized'] = df['HIX_normalized'].replace(0, mean_hix)

    # 2. 最后的防线：填充所有空值
    df = df.fillna(df.mean(numeric_only=True))

    print(f"实际用于训练的行数: {len(df)}")  # 这里必须是 160+

    if len(df) < 50:
        print("数据量严重不足，无法进行机器学习。")
        exit()

    # -------------------
    # 训练模型 (使用你原本用过的 RandomForest 和 GradientBoosting)
    # -------------------
    print("\n>>> 正在训练模型...")

    X = df[["PS", "KOH", "Microwave"]]
    y = df["HIX_normalized"]

    # 标准化
    scaler = StandardScaler()
    X_scaled = scaler.fit_transform(X)

    X_train, X_test, y_train, y_test = train_test_split(X_scaled, y, test_size=0.2, random_state=42)

    # 模型 1: 随机森林 (通常最稳)
    rf = RandomForestRegressor(n_estimators=200, max_depth=10, random_state=42)
    rf.fit(X_train, y_train)
    r2_rf = rf.score(X_test, y_test)

    # 模型 2: 梯度提升 (XGBoost的简化版，通常更准)
    gb = GradientBoostingRegressor(n_estimators=100, learning_rate=0.1, max_depth=3, random_state=42)
    gb.fit(X_train, y_train)
    r2_gb = gb.score(X_test, y_test)

    print("-" * 30)
    print(f"随机森林 (RandomForest) Test R2:     {r2_rf:.4f}")
    print(f"梯度提升 (GradientBoosting) Test R2: {r2_gb:.4f}")
    print("-" * 30)

    # 选择最好的模型进行预测
    best_model = rf if r2_rf > r2_gb else gb
    best_name = "RandomForest" if r2_rf > r2_gb else "GradientBoosting"

    # -------------------
    # 寻找最优条件
    # -------------------
    if max(r2_rf, r2_gb) > 0.3:
        print(f"\n>>> 使用表现最好的模型 ({best_name}) 寻找最优条件...")

        # 生成网格
        p_range = np.linspace(df['PS'].min(), df['PS'].max(), 30)
        k_range = np.linspace(df['KOH'].min(), df['KOH'].max(), 30)
        m_val = 60  # 假设固定微波 60s，你可以改

        best_val = -1
        best_cond = None

        # 暴力搜索
        for p in p_range:
            for k in k_range:
                # 注意：预测时也要标准化
                input_data = scaler.transform([[p, k, m_val]])
                pred = best_model.predict(input_data)[0]

                if pred > best_val:
                    best_val = pred
                    best_cond = (p, k)

        print(f"【最优方案】")
        print(f"PS 浓度:   {best_cond[0]:.2f}")
        print(f"KOH 浓度:  {best_cond[1]:.2f}")
        print(f"微波时间:  {m_val}")
        print(f"预测 HIX:  {best_val:.4f}")
    else:
        print("\n模型拟合度较低 (R2 < 0.3)，暂不推荐最优条件。请检查数据规律。")
