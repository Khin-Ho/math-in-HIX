import os
import re
import numpy as np
import pandas as pd
from sklearn.preprocessing import StandardScaler

# =========================
# Sample physicochemical properties dictionary
# Key: sample name; value: pH, moisture, C/N, ash, OM
# =========================
sample_properties = {
    "milk": {"pH": 6.8, "Moisture": 87.0, "CN": 15.0, "Ash": 0.9, "OM": 12.1},
    "glu": {"pH": 4.2, "Moisture": 50.0, "CN": 1e6, "Ash": 0.08, "OM": 50.0},
    "carrot": {"pH": 6.4, "Moisture": 89, "CN": 45.0, "Ash": 1, "OM": 9.9},
    # 其他样品可以在这里添加
}

# =========================
# EEM reader
# =========================
def read_hitachi_eem(filepath):
    with open(filepath, 'r', encoding='utf-8', errors='ignore') as f:
        lines = f.readlines()
    start_idx = None
    for i, line in enumerate(lines):
        if line.strip().startswith("Peaks"):
            start_idx = i + 2
            break
    if start_idx is None:
        return pd.DataFrame()
    data = []
    for line in lines[start_idx:]:
        parts = re.split(r'\s+', line.strip())
        if len(parts) < 3:
            continue
        try:
            ex_em = parts[1].replace(',', '').strip()
            intensity = float(parts[2])
            if '/' in ex_em:
                ex, em = ex_em.split('/')
            elif '\\' in ex_em:
                ex, em = ex_em.split('\\')
            else:
                ex = parts[0]
                em = parts[1]
            data.append([float(ex), float(em), intensity])
        except Exception:
            continue
    if len(data) == 0:
        return pd.DataFrame()
    df = pd.DataFrame(data, columns=['Ex', 'Em', 'Intensity'])
    eem = df.pivot_table(index='Ex', columns='Em', values='Intensity', aggfunc='mean')
    eem.index = eem.index.astype(float)
    eem.columns = eem.columns.astype(float)
    return eem.sort_index(axis=0).sort_index(axis=1)

# =========================
# Compute R1-R5 + HIX_normalized
# =========================
def calc_features(eem):
    if eem.empty:
        return {f"R{i}": np.nan for i in range(1, 6)}, np.nan

    def mean_region(eem, ex_range, em_range):
        sub = eem.loc[
            (eem.index >= ex_range[0]) & (eem.index <= ex_range[1]),
            (eem.columns >= em_range[0]) & (eem.columns <= em_range[1])
        ]
        if sub.empty or sub.stack().dropna().empty:
            return np.nan
        return sub.mean().mean()

    regions = {
        "R1": mean_region(eem, (200, 250), (250, 330)),
        "R2": mean_region(eem, (200, 250), (330, 380)),
        "R3": mean_region(eem, (200, 250), (380, 550)),
        "R4": mean_region(eem, (250, 380), (250, 380)),
        "R5": mean_region(eem, (250, 450), (380, 550)),
    }

    ex_target = 254
    if ex_target in eem.index:
        row = eem.loc[ex_target]
    else:
        try:
            eem_interp = eem.reindex(eem.index.union([ex_target])).sort_index()
            eem_interp = eem_interp.interpolate(method='index', axis=0, limit_direction='both')
            row = eem_interp.loc[ex_target]
        except Exception:
            diffs = np.abs(eem.index.to_numpy() - ex_target)
            nearest_ex = eem.index.to_numpy()[np.argmin(diffs)]
            row = eem.loc[nearest_ex]

    low_vals = row[(row.index >= 300) & (row.index <= 345)].dropna()
    high_vals = row[(row.index >= 435) & (row.index <= 480)].dropna()

    if low_vals.empty or high_vals.empty:
        return regions, np.nan

    low_mean = low_vals.mean()
    high_mean = high_vals.mean()
    if (low_mean + high_mean) == 0:
        return regions, np.nan

    HIX_norm = high_mean / (low_mean + high_mean)
    return regions, HIX_norm

# =========================
# Parse sample conditions: PS, KOH, Microwave
# =========================
def parse_sample_conditions(sample_label):
    PS, KOH, microwave = 0, 0, 0
    label_split = re.split(r'[-_()]', sample_label)
    base_name = label_split[0]
    nums = re.findall(r'\d+', sample_label)
    if len(nums) >= 3:
        PS, KOH, microwave = map(float, nums[:3])
    elif len(nums) == 2:
        PS, KOH = map(float, nums[:2])
    elif len(nums) == 1:
        PS = float(nums[0])
    return base_name, PS, KOH, microwave

# =========================
# Main
# =========================
if __name__ == "__main__":
    folder = r"E:\desktop\1"  # Your txt folder
    save_folder = os.path.join(folder, "ML_ready")
    os.makedirs(save_folder, exist_ok=True)

    results = []

    for file in os.listdir(folder):
        if not file.lower().endswith(".txt"):
            continue
        path = os.path.join(folder, file)
        sample_label = os.path.splitext(file)[0]

        try:
            eem = read_hitachi_eem(path)
            regions, HIX_norm = calc_features(eem)
            base_name, PS, KOH, microwave = parse_sample_conditions(sample_label)
            props = sample_properties.get(base_name, {"pH": np.nan, "Moisture": np.nan, "CN": np.nan, "Ash": np.nan, "OM": np.nan})
            row = [sample_label, PS, KOH, microwave, HIX_norm,
                   props["pH"], props["Moisture"], props["CN"], props["Ash"], props["OM"]] + [regions[f"R{i}"] for i in range(1, 6)]
            results.append(row)
            print(f"OK {sample_label}: HIX_norm={HIX_norm}")
        except Exception as e:
            print(f"ERR {sample_label}: failed -> {e}")
            results.append([sample_label, 0, 0, 0, np.nan] + [np.nan]*10)

    columns = ["Sample","PS","KOH","Microwave","HIX_normalized","pH","Moisture","CN","Ash","OM",
               "R1","R2","R3","R4","R5"]
    df = pd.DataFrame(results, columns=columns)

    # -------------------
    # Missing value handling
    # -------------------
    df = df.dropna(subset=["HIX_normalized"])
    for col in ["R1","R2","R3","R4","R5","pH","Moisture","CN","Ash","OM","PS","KOH"]:
        df[col] = df[col].fillna(df[col].mean())
        
    # -------------------
    # Feature scaling
    # -------------------
    scaler = StandardScaler()
    feature_cols = ["R1","R2","R3","R4","R5","pH","Moisture","CN","Ash","OM","PS","KOH"]
    df[feature_cols] = scaler.fit_transform(df[feature_cols])

    # -------------------
    # Save CSV
    # -------------------
    save_path = os.path.join(save_folder, "ML_ready_HIX_with_props.csv")
    df.to_csv(save_path, index=False, encoding="utf-8-sig")

    print(f"\nOK CSV saved: {save_path}")
    print(df.head())
