import os
import re
import numpy as np
import pandas as pd
from sklearn.preprocessing import StandardScaler

# =========================
# 读取 Hitachi EEM 文件
# =========================
def read_hitachi_eem(filepath):
    with open(filepath, 'r', encoding='utf-8', errors='ignore') as f:
        lines = f.readlines()

    start_idx = None
    for i, line in enumerate(lines):
        if line.strip().startswith("Peaks"):
            start_idx = i + 2
            break
    if start_idx is None:
        return pd.DataFrame()

    data = []
    for line in lines[start_idx:]:
        parts = re.split(r'\s+', line.strip())
        if len(parts) < 3:
            continue
        try:
            ex_em = parts[1].replace(',', '').strip()
            intensity = float(parts[2])

            if '/' in ex_em:
                ex, em = ex_em.split('/')
            elif '\\' in ex_em:
                ex, em = ex_em.split('\\')
            else:
                ex = parts[0]
                em = parts[1]

            data.append([float(ex), float(em), intensity])
        except Exception:
            continue

    if len(data) == 0:
        return pd.DataFrame()

    df = pd.DataFrame(data, columns=['Ex', 'Em', 'Intensity'])
    eem = df.pivot_table(index='Ex', columns='Em', values='Intensity', aggfunc='mean')

    eem.index = eem.index.astype(float)
    eem.columns = eem.columns.astype(float)
    return eem.sort_index(axis=0).sort_index(axis=1)

# =========================
# 计算 region1-region5（积分体积） + HIX_normalized
# =========================
def calc_features(eem):
    if eem.empty:
        return {f"region{i}": np.nan for i in range(1, 6)}, np.nan

    # ========= 计算 ΔEx 和 ΔEm =========
    ex_vals = eem.index.to_numpy()
    em_vals = eem.columns.to_numpy()

    d_ex = np.min(np.diff(np.sort(ex_vals))) if len(ex_vals) > 1 else 1
    d_em = np.min(np.diff(np.sort(em_vals))) if len(em_vals) > 1 else 1

    # ========= 区域积分体积 =========
    def volume_region(eem, ex_range, em_range):
        sub = eem.loc[
            (eem.index >= ex_range[0]) & (eem.index <= ex_range[1]),
            (eem.columns >= em_range[0]) & (eem.columns <= em_range[1])
        ]
        if sub.empty:
            return np.nan

        intensities = sub.stack().dropna()
        if intensities.empty:
            return np.nan

        return intensities.sum() * d_ex * d_em

    regions = {
        "region1": volume_region(eem, (200, 250), (250, 330)),
        "region2": volume_region(eem, (200, 250), (330, 380)),
        "region3": volume_region(eem, (200, 250), (380, 550)),
        "region4": volume_region(eem, (250, 380), (250, 380)),
        "region5": volume_region(eem, (250, 450), (380, 550)),
    }

    # ========= 总荧光量 =========
    phi_T_n = sum([v for v in regions.values() if not pd.isna(v)])

    # ========= 百分比计算 =========
    region_pct = {}
    for i in range(1,6):
        val = regions[f"region{i}"]
        if pd.isna(val) or phi_T_n == 0:
            region_pct[f"region{i}_pct"] = np.nan
        else:
            region_pct[f"region{i}_pct"] = val / phi_T_n * 100

    # ========= HIX_normalized =========
    ex_target = 254
    if ex_target in eem.index:
        row = eem.loc[ex_target]
    else:
        try:
            eem_interp = eem.reindex(eem.index.union([ex_target])).sort_index()
            eem_interp = eem_interp.interpolate(method='index', axis=0, limit_direction='both')
            row = eem_interp.loc[ex_target]
        except Exception:
            diffs = np.abs(eem.index.to_numpy() - ex_target)
            nearest_ex = eem.index.to_numpy()[np.argmin(diffs)]
            row = eem.loc[nearest_ex]

    low_vals = row[(row.index >= 300) & (row.index <= 345)].dropna()
    high_vals = row[(row.index >= 435) & (row.index <= 480)].dropna()

    if low_vals.empty or high_vals.empty:
        HIX_norm = np.nan
    else:
        low_mean = low_vals.mean()
        high_mean = high_vals.mean()
        HIX_norm = high_mean / (low_mean + high_mean) if (low_mean + high_mean) != 0 else np.nan

    return regions, HIX_norm, phi_T_n, region_pct

# =========================
# 稳健解析样品条件（只读取 PS+KOH+Microwave）
# =========================
def parse_sample_conditions(sample_label):
    PS, KOH, Microwave = 0, 0, 0

    pattern = r'(\d+\.?\d*)\+(\d+\.?\d*)(?:\+(\d+\.?\d*))?'
    match = re.search(pattern, sample_label)
    if match:
        PS = float(match.group(1))
        KOH = float(match.group(2))
        Microwave = float(match.group(3)) if match.group(3) else 0

    return PS, KOH, Microwave

# =========================
# 主程序
# =========================
if __name__ == "__main__":
    folder = r"E:\桌面\try"
    save_folder = os.path.join(folder, "ML_ready")
    os.makedirs(save_folder, exist_ok=True)

    results = []

    for file in os.listdir(folder):
        if not file.lower().endswith(".txt"):
            continue

        path = os.path.join(folder, file)
        sample_label = os.path.splitext(file)[0]

        try:
            eem = read_hitachi_eem(path)
            regions, HIX_norm, total_fluorescence, region_pct = calc_features(eem)
            PS, KOH, Microwave = parse_sample_conditions(sample_label)

            row = [sample_label, PS, KOH, Microwave, HIX_norm, total_fluorescence]
            row += [regions[f"region{i}"] for i in range(1,6)]
            row += [region_pct[f"region{i}_pct"] for i in range(1,6)]

            results.append(row)

            print(f"✅ {sample_label}: PS={PS}, KOH={KOH}, Microwave={Microwave}, HIX_norm={HIX_norm}")
        except Exception as e:
            print(f"❌ {sample_label}: 出错 -> {e}")
            row = [sample_label, 0, 0, 0, np.nan, np.nan] + [np.nan]*5 + [np.nan]*5
            results.append(row)

    df = pd.DataFrame(results, columns=[
        "Sample", "PS", "KOH", "Microwave", "HIX_normalized", "total_fluorescence",
        "region1", "region2", "region3", "region4", "region5",
        "region1_pct", "region2_pct", "region3_pct", "region4_pct", "region5_pct"
    ])

    # ============= 缺失值处理 =============
    df = df.dropna(subset=["HIX_normalized"])
    for col in ["region1","region2","region3","region4","region5"]:
        df[col] = df[col].fillna(df[col].mean())
    for col in ["region1_pct","region2_pct","region3_pct","region4_pct","region5_pct"]:
        df[col] = df[col].fillna(df[col].mean())

    # ============= 特征标准化 =============
    scaler = StandardScaler()
    feature_cols = ["region1","region2","region3","region4","region5","PS","KOH","Microwave"]
    df[feature_cols] = scaler.fit_transform(df[feature_cols])

    # ============= 保存 CSV =============
    save_path = os.path.join(save_folder, "HIX.csv")
    df.to_csv(save_path, index=False, encoding="utf-8-sig")

    print(f"\n✅ CSV 已生成，可直接用于回归模型：{save_path}")
    print(df.head())
